  "keyFeatures": [
    "Misconfiguration scanning against NSA-CISA, MITRE ATT&CK, and CIS Benchmarks",
    "Container image vulnerability scanning using Grype",
    "Automatic remediation of misconfigurations in manifest files",
    "Image patching using Copacetic and BuildKit",
    "Validating Admission Policy (VAP) management with CEL",
    "In-cluster continuous monitoring via Helm operator",
    "eBPF-based runtime security via Inspektor Gadget",
    "MCP server for AI assistant integration",
    "Offline/air-gapped environment support",
    "CI/CD integration with GitHub Actions, GitLab CI, and Jenkins"
  ],
  "publicApiSurface": [
    "kubescape scan",
    "kubescape scan framework <name>",
    "kubescape scan control <id>",
    "kubescape scan workload <kind>/<name>",
    "kubescape scan image <image>:<tag>",
    "kubescape fix <report-file>",
    "kubescape patch --image <image>",
    "kubescape list frameworks|controls",
    "kubescape download artifacts|framework|control",
    "kubescape vap deploy-library",
    "kubescape vap create-policy-binding",
    "kubescape operator scan configurations|vulnerabilities",
    "kubescape mcpserver",
    "kubescape config view|set|delete",
    "kubescape completion bash|zsh|fish|powershell",
    "kubescape version"
  ]
